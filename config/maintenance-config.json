{
  "_metadata": {
    "version": "4.2.0",
    "description": "Windows Maintenance Framework Configuration File - Modular Architecture",
    "last_updated": "2026-02-14",
    "author": "Miguel Velasco",
    "notes": "Modular architecture with comprehensive logging, NetworkMaintenance module, and Task Scheduler integration"
  },
  "_instructions": "Modify values below to customize script behavior. Remove metadata and instructions sections if not needed.",
  
  "LogsPath": "C:\\Users\\Miguel\\Documents\\Maintenance\\Logs",
  "ReportsPath": "C:\\Users\\Miguel\\Documents\\Maintenance\\Reports",
  
  "MaxLogSizeMB": 100,
  "MaxBackupDays": 30,
  "MaxEventLogSizeMB": 10,
  "MinFreeSpaceGB": 5,
  
  "DetailedLogging": true,
  "ProgressReporting": true,
  "TimeoutMinutes": 30,
  "MaxParallelJobs": 2,
  "MemoryOptimizeInterval": 5,
  
  "EnabledModules": [
    "SystemUpdates",
    "DiskMaintenance",
    "SystemHealthRepair",
    "SecurityScans",
    "DeveloperMaintenance",
    "MultimediaMaintenance",
    "PerformanceOptimization",
    "NetworkMaintenance",
    "GPUMaintenance",
    "EventLogManagement",
    "BackupOperations",
    "BloatwareRemoval",
    "PrivacyMaintenance",
    "SystemReporting"
  ],
  
  "DriveDetection": true,
  "AutoEventLogArchival": false,
  "Reporting": true,
  "SkipLinuxPartitions": true,
  "SkipNetworkDrives": true,
  "ValidateHardwareSupport": true,
  "EnableFastMode": false,
  "ParallelProcessing": true,
  "AggressiveCleanup": true,
  
  "EventLogManagement": {
    "_description": "Event Log Archival and Optimization Configuration",
    "ManageEventLogs": true,
    "MaxEventLogSizeMB": 50,
    "RetentionDays": 30,
    "ArchiveDirectory": "%ReportsPath%\\EventLogArchives"
  },

  "BackupOperations": {
    "_description": "System Backup and Restore Point Configuration",
    "EnableRestorePoint": true,
    "EnableFileBackup": false,
    "BackupMode": "RestorePoint",
    "KeepDays": 30,
    "KeepMinimum": 5,
    "BackupPath": "C:\\Users\\Miguel\\Documents\\Backups",
    "Description": "Maintenance Script Backup"
  },

  "SystemReporting": {
    "_description": "System Reporting and Summary Configuration",
    "GenerateComprehensiveReport": true,
    "IncludeDiskAnalysis": true,
    "IncludeNetworkAnalysis": true,
    "IncludeSecurityStatus": true
  },

  "GPUMaintenance": {
    "_description": "GPU Shader Cache and Optimization Configuration",
    "EnableNVIDIACleanup": true,
    "EnableAMDCleanup": true,
    "EnableIntelCleanup": true,
    "EnableDirectXCleanup": true,
    "ShaderCacheRetentionDays": 1
  },
  
  "MultimediaMaintenance": {
    "_description": "Multimedia Software Maintenance Configuration",
    "EnableAdobeSuite": true,
    "EnableDaVinciResolve": true,
    "EnableCapCut": true,
    "EnableAudacity": true,
    "EnableOBSStudio": true,
    "LogRetentionDays": 7,
    "MediaCacheRetentionDays": 30
  },

  "SystemHealthRepair": {
    "_description": "System Health & Repair Module Configuration",
    "EnableDISM": true,
    "EnableSFC": true,
    "EnableCHKDSK": true,
    "DISMTimeout": 30,
    "SFCTimeout": 20,
    "AutoRepair": true,
    "ScheduleCHKDSKOnErrors": true,

    "_advanced_settings": "Advanced configuration for enterprise environments",
    "SkipDISMIfHealthy": true,
    "SkipSFCIfDISMHealthy": false,
    "GenerateDetailedReports": true,
    "NotifyOnRepairs": true,
    "ForceOfflineScan": false,

    "_timeout_notes": "Timeouts in minutes. DISM can take 15-45 minutes, SFC can take 10-30 minutes. CHKDSK requires restart and runs at boot.",
    "_repair_notes": "AutoRepair will automatically attempt to fix detected issues using /RestoreHealth for DISM and automatic repair for SFC",
    "_chkdsk_notes": "CHKDSK is disabled by default as it requires system restart. Enable only if disk errors are suspected."
  },
  
  "DiskMaintenance": {
    "_description": "Disk Maintenance and Optimization Configuration",
    "EnableCleanup": true,
    "EnableOptimization": true,
    "EnableWindowsCleanup": true,
    "EnableRecycleBinCleanup": false,

    "_cleanup_settings": "Temporary file cleanup configuration",
    "CleanupLocations": [
      {
        "Path": "%TEMP%",
        "Name": "User Temp",
        "Priority": "High",
        "RetentionDays": 7
      },
      {
        "Path": "%SystemRoot%\\Temp",
        "Name": "System Temp",
        "Priority": "High",
        "RetentionDays": 7
      },
      {
        "Path": "%SystemRoot%\\SoftwareDistribution\\Download",
        "Name": "Windows Update Cache",
        "Priority": "Medium",
        "RetentionDays": 14
      },
      {
        "Path": "%LOCALAPPDATA%\\Microsoft\\Windows\\INetCache",
        "Name": "Internet Cache",
        "Priority": "Low",
        "RetentionDays": 30
      },
      {
        "Path": "%SystemRoot%\\Logs",
        "Name": "Windows Logs",
        "Priority": "Low",
        "RetentionDays": 90
      },
      {
        "Path": "%LOCALAPPDATA%\\Temp",
        "Name": "Local Temp",
        "Priority": "Medium",
        "RetentionDays": 7
      }
    ],

    "_optimization_settings": "Disk optimization configuration",
    "OptimizeSSDs": true,
    "DefragmentHDDs": true,
    "AnalyzeBeforeOptimize": true,
    "SkipExternalDrives": false,
    "MinimumFragmentation": 10,
    "EnableTRIM": true,
    "OptimizationPriority": "Normal",

    "_advanced_settings": "Advanced disk maintenance settings",
    "CleanupTimeout": 30,
    "EmergencyThresholdGB": 2,
    "AutoEmergencyCleanup": false,
    "StateFlag": 1001,

    "_notes": "OptimizeSSDs runs TRIM on SSDs. DefragmentHDDs only defragments traditional HDDs. RecycleBin cleanup is disabled by default for safety. EmergencyCleanup activates when free space drops below threshold."
  },
  
  "SystemUpdates": {
    "_description": "System Updates Module Configuration",
    "EnableWindowsUpdate": true,
    "EnableWUReset": false,
    "EnableWinGet": true,
    "EnableChocolatey": true,
    "AutoInstallUpdates": true,
    "UpdateTimeout": 60,
    "IncludeOptionalUpdates": true,
    "RestartAfterUpdates": true,
    "DownloadOnly": false
  },
  
  "SecurityScans": {
    "_description": "Security Scanning Configuration",
    "EnableDefenderScan": true,
    "ScanLevel": "Quick",
    "DefenderTimeout": 30,
    "EnableSecurityPolicyAudit": true,
    "EnableFirewallCheck": true,
    "SkipIfRecentScan": true,
    "RecentScanThresholdHours": 24,

    "_advanced_settings": "Advanced security scan configuration",
    "DetectConflictingAV": true,
    "UpdateDefinitionsBeforeScan": true,
    "ScanRemovableDrives": false,

    "_notes": "Quick scan is recommended for routine maintenance. Full scan can take 1-3 hours. SkipIfRecentScan prevents redundant scans. Defender will skip scanning if conflicting antivirus is detected."
  },
  
  "DeveloperMaintenance": {
    "_description": "Developer Tools Maintenance Configuration",
    "EnableNPM": true,
    "EnablePython": true,
    "EnableDocker": true,
    "EnableJDK": true,
    "EnableMinGW": true,
    "EnableDotNetSDK": true,
    "EnableWindowsSDK": true,
    "EnableVCRedist": true,
    "EnableComposer": true,
    "EnablePostgreSQL": true,
    "EnableJetBrainsIDEs": true,
    "EnableVisualStudio": true,
    "EnableVSCode": true,
    "EnableSSMS": true,
    "EnableDatabaseTools": true,
    "EnableVersionControl": true,
    "EnableLegacyCppTools": true,

    "_advanced_settings": "Advanced developer tools configuration",
    "NPMCacheRetentionDays": 30,
    "PythonCacheRetentionDays": 30,
    "PIMCacheRetentionDays": 30,
    "DockerCleanupAggressiveness": "Medium",
    "JDKCacheRetentionDays": 90,
    "UpdateDevTools": true,

    "_notes": "Only enable tools that are installed on your system. Setting tools to true when not installed will be safely skipped. UpdateDevTools will attempt to update package managers (npm, pip, etc.) which may take additional time."
  },
  
  "PerformanceOptimization": {
    "_description": "Performance Optimization Configuration",
    "EnableStartupOptimization": true,
    "EnableEventLogCleanup": true,
    "EnableMemoryOptimization": true,
    "RemoveInvalidStartupItems": true,
    "AnalyzeStartupImpact": true,
    "EnableResourceAnalysis": true,
    "EventLogRetentionDays": 30,
    "MaxEventLogSizeMB": 20
  },

  "PrivacyMaintenance": {
    "_description": "Privacy and Telemetry Maintenance Configuration",
    "DisableTelemetryServices": true,
    "DisablePrivacyRegistryPolicies": true
  },

  "BloatwareRemoval": {
    "_description": "UWP Bloatware Removal Configuration",
    "EnableUWPRemoval": true,
    "KeepStandardApps": true
  },

  "NetworkMaintenance": {
    "_description": "Network Maintenance and Diagnostics Configuration",
    "EnableDNSCacheClear": true,
    "EnableARPCacheClear": true,
    "EnableNetBIOSCacheClear": true,
    "EnableConnectivityTest": true,
    "EnableAdapterAnalysis": true,
    "EnableWinsockReset": false,

    "_advanced_settings": "Advanced network diagnostics configuration",
    "ConnectivityTestEndpoints": [
      "8.8.8.8",
      "1.1.1.1",
      "www.google.com",
      "www.microsoft.com"
    ],
    "ConnectivityTimeout": 5,
    "RequireUserConfirmationForWinsockReset": true,

    "_notes": "DNS, ARP, and NetBIOS cache clearing are safe and recommended. Winsock reset should only be enabled if experiencing persistent network issues and may require restart."
  },
  
  "_notification_settings": {
    "_description": "User notification preferences",
    "ShowMessageBoxes": false,
    "SilentMode": true,
    "NotifyOnErrors": true,
    "NotifyOnCompletion": true,
    "EmailNotifications": false
  },
  
  "_performance_tuning": {
    "_description": "Performance tuning options",
    "FastMode": false,
    "ReducedTimeout": false,
    "SkipNonCritical": false,
    "ParallelExecution": true,
    "MaxConcurrentOperations": 2
  },
  
  "_safety_settings": {
    "_description": "Safety and validation settings",
    "WhatIfMode": false,
    "ValidateBeforeDelete": true,
    "CreateBackupBeforeChanges": true,
    "MinimumDiskSpaceGB": 5,
    "ConfirmDangerousOperations": true
  },
  
  "_scheduling": {
    "_description": "Scheduling preferences (external scheduler required)",
    "RecommendedFrequency": "Weekly",
    "BestExecutionTime": "Off-hours",
    "EstimatedDuration": "30-60 minutes",
    "RequiresRestart": false
  }
}
