{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yourusername/windows-maintenance/config/maintenance-config.schema.json",
  "title": "Windows Maintenance Configuration Schema",
  "description": "JSON schema for validating Windows Maintenance Framework configuration files",
  "type": "object",
  "required": ["EnabledModules", "LogsPath", "ReportsPath"],
  "properties": {
    "_metadata": {
      "type": "object",
      "description": "Configuration metadata (optional)",
      "properties": {
        "version": { "type": "string" },
        "description": { "type": "string" },
        "last_updated": { "type": "string" },
        "author": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "_instructions": {
      "type": "string",
      "description": "User instructions (optional)"
    },
    "LogsPath": {
      "type": "string",
      "description": "Path where log files will be stored",
      "minLength": 1
    },
    "ReportsPath": {
      "type": "string",
      "description": "Path where report files will be stored",
      "minLength": 1
    },
    "MaxLogSizeMB": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "default": 100
    },
    "MaxBackupDays": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365,
      "default": 30
    },
    "MaxEventLogSizeMB": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "default": 100
    },
    "MinFreeSpaceGB": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 5
    },
    "DetailedLogging": {
      "type": "boolean",
      "default": true
    },
    "ProgressReporting": {
      "type": "boolean",
      "default": true
    },
    "TimeoutMinutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 240,
      "default": 30
    },
    "MaxParallelJobs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8,
      "default": 2
    },
    "MemoryOptimizeInterval": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60,
      "default": 5
    },
    "EnabledModules": {
      "type": "array",
      "description": "List of enabled maintenance modules",
      "items": {
        "type": "string",
        "enum": [
          "SystemUpdates",
          "DiskMaintenance",
          "SystemHealthRepair",
          "SecurityScans",
          "DeveloperMaintenance",
          "MultimediaMaintenance",
          "PerformanceOptimization",
          "NetworkMaintenance",
          "GPUMaintenance",
          "EventLogManagement",
          "BackupOperations",
          "BloatwareRemoval",
          "PrivacyMaintenance",
          "SystemReporting"
        ]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "DriveDetection": { "type": "boolean", "default": true },
    "AutoEventLogArchival": { "type": "boolean", "default": false },
    "Reporting": { "type": "boolean", "default": true },
    "SkipLinuxPartitions": { "type": "boolean", "default": true },
    "SkipNetworkDrives": { "type": "boolean", "default": true },
    "ValidateHardwareSupport": { "type": "boolean", "default": true },
    "EnableFastMode": { "type": "boolean", "default": false },
    "ParallelProcessing": { "type": "boolean", "default": true },
    "AggressiveCleanup": { "type": "boolean", "default": false },
    
    "SystemHealthRepair": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableDISM": { "type": "boolean", "default": true },
        "EnableSFC": { "type": "boolean", "default": true },
        "EnableCHKDSK": { "type": "boolean", "default": false },
        "DISMTimeout": { "type": "integer", "default": 30 },
        "SFCTimeout": { "type": "integer", "default": 20 },
        "AutoRepair": { "type": "boolean", "default": true },
        "ScheduleCHKDSKOnErrors": { "type": "boolean", "default": false },
        "SkipDISMIfHealthy": { "type": "boolean", "default": true },
        "SkipSFCIfDISMHealthy": { "type": "boolean", "default": false },
        "GenerateDetailedReports": { "type": "boolean", "default": true },
        "NotifyOnRepairs": { "type": "boolean", "default": true },
        "ForceOfflineScan": { "type": "boolean", "default": false },
        "_advanced_settings": { "type": "string" },
        "_timeout_notes": { "type": "string" },
        "_repair_notes": { "type": "string" },
        "_chkdsk_notes": { "type": "string" }
      }
    },
    
    "DiskMaintenance": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableCleanup": { "type": "boolean", "default": true },
        "EnableOptimization": { "type": "boolean", "default": true },
        "EnableWindowsCleanup": { "type": "boolean", "default": true },
        "EnableRecycleBinCleanup": { "type": "boolean", "default": false },
        "CleanupLocations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Path": { "type": "string" },
              "Name": { "type": "string" },
              "Priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
              "RetentionDays": { "type": "integer" }
            }
          }
        },
        "OptimizeSSDs": { "type": "boolean", "default": true },
        "DefragmentHDDs": { "type": "boolean", "default": true },
        "AnalyzeBeforeOptimize": { "type": "boolean", "default": true },
        "SkipExternalDrives": { "type": "boolean", "default": false },
        "MinimumFragmentation": { "type": "integer", "default": 10 },
        "EnableTRIM": { "type": "boolean", "default": true },
        "OptimizationPriority": { "type": "string", "enum": ["Low", "Normal", "High"], "default": "Normal" },
        "CleanupTimeout": { "type": "integer", "default": 30 },
        "EmergencyThresholdGB": { "type": "integer", "default": 2 },
        "AutoEmergencyCleanup": { "type": "boolean", "default": false },
        "StateFlag": { "type": "integer", "default": 1001 },
        "_cleanup_settings": { "type": "string" },
        "_optimization_settings": { "type": "string" },
        "_advanced_settings": { "type": "string" },
        "_notes": { "type": "string" }
      }
    },
    
    "SystemUpdates": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableWindowsUpdate": { "type": "boolean", "default": true },
        "EnableWUReset": { "type": "boolean", "default": false },
        "EnableWinGet": { "type": "boolean", "default": true },
        "EnableChocolatey": { "type": "boolean", "default": true },
        "EnableMicrosoftStore": { "type": "boolean", "default": true },
        "AutoInstallUpdates": { "type": "boolean", "default": false },
        "UpdateTimeout": { "type": "integer", "default": 60 },
        "IncludeOptionalUpdates": { "type": "boolean", "default": false },
        "RestartAfterUpdates": { "type": "boolean", "default": false },
        "DownloadOnly": { "type": "boolean", "default": false }
      }
    },
    
    "SecurityScans": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableDefenderScan": { "type": "boolean", "default": true },
        "ScanLevel": { "type": "string", "enum": ["Quick", "Full", "Custom"], "default": "Quick" },
        "DefenderTimeout": { "type": "integer", "default": 30 },
        "EnableSecurityPolicyAudit": { "type": "boolean", "default": false },
        "EnableFirewallCheck": { "type": "boolean", "default": false },
        "SkipIfRecentScan": { "type": "boolean", "default": true },
        "RecentScanThresholdHours": { "type": "integer", "default": 24 },
        "DetectConflictingAV": { "type": "boolean", "default": true },
        "UpdateDefinitionsBeforeScan": { "type": "boolean", "default": true },
        "ScanRemovableDrives": { "type": "boolean", "default": false },
        "_advanced_settings": { "type": "string" },
        "_notes": { "type": "string" }
      }
    },
    
    "DeveloperMaintenance": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableNPM": { "type": "boolean", "default": true },
        "EnablePython": { "type": "boolean", "default": true },
        "EnableDocker": { "type": "boolean", "default": true },
        "EnableJDK": { "type": "boolean", "default": true },
        "EnableMinGW": { "type": "boolean", "default": false },
        "EnableDotNetSDK": { "type": "boolean", "default": false },
        "EnableWindowsSDK": { "type": "boolean", "default": false },
        "EnableVCRedist": { "type": "boolean", "default": false },
        "EnableComposer": { "type": "boolean", "default": false },
        "EnablePostgreSQL": { "type": "boolean", "default": false },
        "EnableJetBrainsIDEs": { "type": "boolean", "default": false },
        "EnableVisualStudio": { "type": "boolean", "default": false },
        "EnableVSCode": { "type": "boolean", "default": false },
        "EnableAzureDataStudio": { "type": "boolean", "default": false },
        "EnableUnity": { "type": "boolean", "default": false },
        "EnableBlender": { "type": "boolean", "default": false },
        "EnableSSMS": { "type": "boolean", "default": false },
        "EnableDatabaseTools": { "type": "boolean", "default": false },
        "EnableVersionControl": { "type": "boolean", "default": true },
        "EnableLegacyCppTools": { "type": "boolean", "default": false },
        "RetentionDays": { "type": "integer", "default": 30 },
        "NPMCacheRetentionDays": { "type": "integer", "default": 30 },
        "PythonCacheRetentionDays": { "type": "integer", "default": 30 },
        "DockerCleanupAggressiveness": { "type": "string", "enum": ["Low", "Medium", "High"], "default": "Medium" },
        "JDKCacheRetentionDays": { "type": "integer", "default": 90 },
        "UpdateDevTools": { "type": "boolean", "default": false },
        "_advanced_settings": { "type": "string" },
        "_notes": { "type": "string" }
      }
    },
    
    "PerformanceOptimization": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableStartupOptimization": { "type": "boolean", "default": true },
        "EnableEventLogCleanup": { "type": "boolean", "default": true },
        "EnableMemoryOptimization": { "type": "boolean", "default": true },
        "RemoveInvalidStartupItems": { "type": "boolean", "default": true },
        "AnalyzeStartupImpact": { "type": "boolean", "default": true },
        "EnableResourceAnalysis": { "type": "boolean", "default": true },
        "EventLogRetentionDays": { "type": "integer", "default": 30 },
        "MaxEventLogSizeMB": { "type": "integer", "default": 20 }
      }
    },
    
    "NetworkMaintenance": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableDNSCacheClear": { "type": "boolean", "default": true },
        "EnableARPCacheClear": { "type": "boolean", "default": true },
        "EnableNetBIOSCacheClear": { "type": "boolean", "default": true },
        "EnableConnectivityTest": { "type": "boolean", "default": true },
        "EnableAdapterAnalysis": { "type": "boolean", "default": true },
        "EnableWinsockReset": { "type": "boolean", "default": false },
        "ConnectivityTestEndpoints": { "type": "array", "items": { "type": "string" } },
        "ConnectivityTimeout": { "type": "integer", "default": 5 },
        "RequireUserConfirmationForWinsockReset": { "type": "boolean", "default": true },
        "_advanced_settings": { "type": "string" },
        "_notes": { "type": "string" }
      }
    },
    
    "GPUMaintenance": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableNVIDIACleanup": { "type": "boolean", "default": true },
        "EnableAMDCleanup": { "type": "boolean", "default": true },
        "EnableIntelCleanup": { "type": "boolean", "default": true },
        "EnableDirectXCleanup": { "type": "boolean", "default": true },
        "ShaderCacheRetentionDays": { "type": "integer", "default": 1 }
      }
    },
    
    "MultimediaMaintenance": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableAdobeSuite": { "type": "boolean", "default": true },
        "EnableDaVinciResolve": { "type": "boolean", "default": true },
        "EnableCapCut": { "type": "boolean", "default": true },
        "EnableAudacity": { "type": "boolean", "default": true },
        "EnableOBSStudio": { "type": "boolean", "default": true },
        "LogRetentionDays": { "type": "integer", "default": 7 },
        "MediaCacheRetentionDays": { "type": "integer", "default": 30 }
      }
    },
    
    "PrivacyMaintenance": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "DisableTelemetryServices": { "type": "boolean", "default": true },
        "DisablePrivacyRegistryPolicies": { "type": "boolean", "default": true }
      }
    },
    
    "BloatwareRemoval": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableUWPRemoval": { "type": "boolean", "default": true },
        "KeepStandardApps": { "type": "boolean", "default": true }
      }
    },
    
    "EventLogManagement": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "ManageEventLogs": { "type": "boolean", "default": true },
        "MaxEventLogSizeMB": { "type": "integer", "default": 50 },
        "RetentionDays": { "type": "integer", "default": 30 },
        "ArchiveDirectory": { "type": "string" }
      }
    },
    
    "BackupOperations": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "EnableRestorePoint": { "type": "boolean", "default": true },
        "EnableFileBackup": { "type": "boolean", "default": false },
        "BackupMode": { "type": "string", "enum": ["RestorePoint", "File", "Full"] },
        "KeepDays": { "type": "integer", "default": 30 },
        "KeepMinimum": { "type": "integer", "default": 5 },
        "BackupPath": { "type": "string" },
        "Description": { "type": "string" }
      }
    },
    
    "SystemReporting": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "GenerateComprehensiveReport": { "type": "boolean", "default": true },
        "IncludeDiskAnalysis": { "type": "boolean", "default": true },
        "IncludeNetworkAnalysis": { "type": "boolean", "default": true },
        "IncludeSecurityStatus": { "type": "boolean", "default": true }
      }
    },
    
    "GUISettings": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "WindowTitle": { "type": "string" },
        "WindowWidth": { "type": "integer", "default": 900 },
        "WindowHeight": { "type": "integer", "default": 800 },
        "RefreshIntervalMS": { "type": "integer", "default": 500 },
        "Theme": {
          "type": "object",
          "properties": {
            "Mode": { "type": "string", "enum": ["Light", "Dark"], "default": "Light" },
            "Colors": {
              "type": "object",
              "properties": {
                "Background": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "Foreground": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "Primary": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "Success": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "Warning": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "Error": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "ConsoleBg": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "ConsoleFg": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
                "Accent": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" }
              }
            }
          }
        }
      }
    },
    
    "_notification_settings": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "ShowMessageBoxes": { "type": "boolean", "default": false },
        "SilentMode": { "type": "boolean", "default": true },
        "NotifyOnErrors": { "type": "boolean", "default": true },
        "NotifyOnCompletion": { "type": "boolean", "default": false },
        "EmailNotifications": { "type": "boolean", "default": false }
      }
    },
    
    "_performance_tuning": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "FastMode": { "type": "boolean", "default": false },
        "ReducedTimeout": { "type": "boolean", "default": false },
        "SkipNonCritical": { "type": "boolean", "default": false },
        "ParallelExecution": { "type": "boolean", "default": true },
        "MaxConcurrentOperations": { "type": "integer", "default": 2 }
      }
    },
    
    "_safety_settings": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "WhatIfMode": { "type": "boolean", "default": false },
        "ValidateBeforeDelete": { "type": "boolean", "default": true },
        "CreateBackupBeforeChanges": { "type": "boolean", "default": true },
        "MinimumDiskSpaceGB": { "type": "integer", "default": 5 },
        "ConfirmDangerousOperations": { "type": "boolean", "default": true }
      }
    },
    
    "_scheduling": {
      "type": "object",
      "properties": {
        "_description": { "type": "string" },
        "RecommendedFrequency": { "type": "string", "enum": ["Daily", "Weekly", "BiWeekly", "Monthly"] },
        "BestExecutionTime": { "type": "string" },
        "EstimatedDuration": { "type": "string" },
        "RequiresRestart": { "type": "boolean", "default": false }
      }
    }
  },
  "additionalProperties": false
}